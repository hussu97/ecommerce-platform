# Discovery API – copy to .env and set values. See discovery-api/README.md for details.

# Database (default: SQLite in discovery.db)
DATABASE_URL=sqlite+aiosqlite:///./discovery.db
# PostgreSQL (Neon): postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/discovery?sslmode=require
# DB_CONNECT_TIMEOUT=30

# SerpApi (Google Shopping, Google Trends) – optional
# SERPAPI_API_KEY=

# Aliexpress True API (RapidAPI – /hot-products)
RAPIDAPI_KEY=
RAPIDAPI_ALIEXPRESS_HOST=aliexpress-true-api.p.rapidapi.com
DISCOVERY_ALIEXPRESS_SHIP_COUNTRY=AE
DISCOVERY_ALIEXPRESS_LANGUAGE=EN

# Discovery filters and query source
DISCOVERY_MAX_ASP_AED=500
USD_TO_AED=3.67
DISCOVERY_QUERY_SOURCE=static
DISCOVERY_TRENDS_GEO=ae
# DISCOVERY_QUERY_LIST=wireless earbuds,yoga mat
# Or path to file: DISCOVERY_QUERY_LIST=data/queries_example.txt

# Phase 2 – Amazon best-seller (optional)
# SELLERMAGNET_API_KEY=
# AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
# AMAZON_CATEGORY_IDS=
# AMAZON_DOMAIN=amazon.com

# Phase 2 – Reddit query source (optional)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_SUBREDDITS=BuyItForLife,Frugal,GiftIdeas

# Phase 2 – TokInsight TikTok query source (optional)
# TOKINSIGHT_API_KEY=
# RAPIDAPI_TOKINSIGHT_HOST=

# DEBUG=True
