# Customer API – copy to .env. See customer-api/README.md and PRODUCTION.md.

# Database
DATABASE_URL=sqlite+aiosqlite:///./ecommerce.db
# PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/ecommerce
# DB_CONNECT_TIMEOUT=30

# Auth
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS – comma-separated frontend origins (no spaces). Production: set to your real origins.
# BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:5173

# Stripe (optional; omit or use test key for dev)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# DEBUG=True
