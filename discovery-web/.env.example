# Discovery Web – copy to .env. Restart dev server after changes.
# See discovery-web/README.md for details.

# Discovery API URL (build-time). When unset, app uses relative /api (Vite proxy in dev).
# VITE_DISCOVERY_API_URL=http://127.0.0.1:8004

# Dev server proxy target (server-side only; default 127.0.0.1:8004)
# In Docker: VITE_PROXY_TARGET=http://discovery-api:8004
# VITE_PROXY_TARGET=http://127.0.0.1:8004
